  <p:ajax event="tabChange"
            listener="#{akteVC.onTabChange}"
            update="@form"/>


public void onTabChange(TabChangeEvent event) {
    // get the tab index that was clicked
    int index = ((TabView) event.getSource()).getActiveIndex();
    activeIndex = index;
    
    // update imsModell currentTab
    switch (index) {
        case 0: imsModell.setCurrentTab(Tab.POSTKORB); break;
        case 1: imsModell.setCurrentTab(Tab.AKTENANSICHT); break;
        case 2: imsModell.setCurrentTab(Tab.AKTENEINTRAEGE); break;
        case 3: imsModell.setCurrentTab(Tab.FORMULAR); break;
        case 4: imsModell.setCurrentTab(Tab.FAXEN); break;
        case 5: imsModell.setCurrentTab(Tab.EMAIL); break;
        case 6: imsModell.setCurrentTab(Tab.BESCHWERDEN); break;
        default: imsModell.setCurrentTab(Tab.POSTKORB); break;
    }
    
    LOG.info("onTabChange - activeIndex: " + activeIndex + 
             " - currentTab: " + imsModell.getCurrentTab());
}

  String tabId = event.getTab().getId();
