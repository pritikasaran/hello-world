public void onRadioChange(String jaKey) {
    // Extract row number from jaKey e.g. "checked11" -> "1"
    String rowNum = jaKey.replace("checked1", "");
    String neinKey = "checked2" + rowNum;
    
    boolean isJa = (boolean) formsModell.getValueMap().get(jaKey).getValue();
    formsModell.getValueMap().get(neinKey).setValue(!isJa);
}

<p:selectOneRadio
    value="#{formsVC.formsModell.valueMap.checked11.value}"
    disabled="#{formsVC.formsModell.valueMap.checked11.locked}">
    <f:selectItem itemValue="true"  itemLabel="Ja" />
    <f:selectItem itemValue="false" itemLabel="Nein" />
    <p:ajax process="@this" 
            listener="#{formsVC.onRadioChange('checked11')}" />
</p:selectOneRadio>
