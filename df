mvn deploy:deploy-file \
  -DgroupId=com.yourorg.gre \
  -DartifactId=gre \
  -Dversion=1.0.0 \
  -Dpackaging=jar \
  -Dfile=gre.jar \
  -DrepositoryId=nexus \
  -Durl=http://your-nexus-server/repository/your-repo/
.ui-toolbar {
    padding: 2px 4px !important;
    min-height: 0 !important;
}
.textfett { 
    font-weight: bold; 
}

/* hide empty text span */
.ui-button-icon-only .ui-button-text {
    display: none !important;
}

/* base button reset */
.ui-button-icon-only {
    width: auto !important;
    height: auto !important;
    padding: 2px !important;
    border: none !important;
    background: transparent !important;
    box-shadow: none !important;
    cursor: pointer !important;
}

/* base icon styles */
.custom-icon {
    width: 16px;
    height: 16px;
    background-repeat: no-repeat;
    background-position: center;
    background-size: contain;
    display: inline-block;
}

/* hover effect on button */
.ui-button-icon-only:hover {
    border: none !important;
    background: #ddeeff !important;
    box-shadow: none !important;
    opacity: 0.8;
}

/* icon slightly dims on hover */
.ui-button-icon-only:hover .custom-icon {
    opacity: 0.75;
}

/* individual icons */
.refresh-btn .custom-icon {
    background-image: url("#{resource['images:refresh.gif']}");
}

.sort-btn .custom-icon {
    background-image: url("#{resource['images:sortieren.gif']}");
}

.bearbeiten-btn .custom-icon {
    background-image: url("#{resource['images:bearbeiten.gif']}");
}

.weiterleiten-btn .custom-icon {
    background-image: url("#{resource['images:weiterleiten.gif']}");
}

.kzaendern-btn .custom-icon {
    background-image: url("#{resource['images:kzaendern2.gif']}");
}

.kke-btn .custom-icon {
    background-image: url("#{resource['images:kke.gif']}");
}

.erledigen-btn .custom-icon {
    background-image: url("#{resource['images:termin_erled.gif']}");
}
