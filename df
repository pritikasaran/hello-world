.ui-button-icon-only {
    width: auto !important;
    height: auto !important;
    padding: 1px !important;
    border: none !important;
    outline: none !important;
    background: transparent !important;
    box-shadow: none !important;
    cursor: pointer !important;
    vertical-align: middle !important;
}

.ui-button-icon-only:focus,
.ui-button-icon-only:hover,
.ui-button-icon-only.ui-state-default,
.ui-button-icon-only.ui-state-hover,
.ui-button-icon-only.ui-state-focus,
.ui-button-icon-only.ui-state-active {
    border: none !important;
    outline: none !important;
    background: transparent !important;
    box-shadow: none !important;
}

/* hide empty text span */
.ui-button-icon-only .ui-button-text {
    display: none !important;
}

/* icon size matching ADF */
.custom-icon {
    width: 22px !important;
    height: 22px !important;
    background-repeat: no-repeat;
    background-position: center;
    background-size: 22px 22px !important;
    display: inline-block !important;
    vertical-align: middle !important;
}

/* compact toolbar */
.ui-toolbar {
    padding: 2px 4px !important;
    min-height: 0 !important;
    background: transparent !important;
    border: none !important;
    border-bottom: 1px solid #cccccc !important;
}

.ui-toolbar .ui-toolbar-group-left,
.ui-toolbar .ui-toolbar-group-right {
    padding: 0 !important;
}

