[Unit]
Description=Companion Application
After=network.target

[Service]
Type=simple
User=athora
WorkingDirectory=/home/athora/ex20708/companion

Environment="JAVA_OPTS=-Dcompanion.home=/home/athora/ex20708/companion \
 -Dspring.config.location=classpath:/application.properties,/home/athora/ex20708/companion/.genre/conf/settings.properties \
 -Dserver.port=9090"

ExecStart=/usr/bin/java $JAVA_OPTS -cp ./lib/*:companion.war org.springframework.boot.loader.WarLauncher

Restart=always
StandardOutput=append:/home/athora/ex20708/companion/logs/companion.out.log
StandardError=append:/home/athora/ex20708/companion/logs/companion.err.log

[Install]
WantedBy=multi-user.target

    <p:tab id="tabPostkorb" title="Postkorb"
           rendered="#{!akteVC.akteModell.imsModell.modusIMS2}">
        
        <!-- Disclosure listener equivalent -->
        <p:ajax event="tabChange" listener="#{akteVC.disclosePostkorb}" update="@form" />
        
        <!-- Clear messages on tab change -->
        <p:ajax event="tabChange" listener="#{akteVC.clearAllMessages}" update="@form" />
        
        <!-- Scrollable content -->
        <h:panelGroup layout="block" style="overflow:auto; max-height:600px;">
            <ui:include src="/pages/postkorb.xhtml" />
        </h:panelGroup>
    </p:tab>
