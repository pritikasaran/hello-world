private String selectedTermine = "aktuelle"; // default

public String getSelectedTermine() { 
    return selectedTermine; 
}

public void setSelectedTermine(String value) {
    this.selectedTermine = value;
    // automatically keeps your 3 booleans in sync
    this.aktuelleTermine    = "aktuelle".equals(value);
    this.zukuenftigeTermine = "zukuenftige".equals(value);
    this.erledigteTermine   = "erledigte".equals(value);
}
