[Unit]
Description=Companion Application
After=network.target

[Service]
Type=simple
User=athora
WorkingDirectory=/home/athora/ex20708/companion

Environment="JAVA_OPTS=-Dcompanion.home=/home/athora/ex20708/companion \
 -Dspring.config.location=classpath:/application.properties,/home/athora/ex20708/companion/.genre/conf/settings.properties \
 -Dserver.port=9090"

ExecStart=/usr/bin/java $JAVA_OPTS -cp ./lib/*:companion.war org.springframework.boot.loader.WarLauncher

Restart=always
StandardOutput=append:/home/athora/ex20708/companion/logs/companion.out.log
StandardError=append:/home/athora/ex20708/companion/logs/companion.err.log

[Install]
WantedBy=multi-user.target

private String selectedTermine = "aktuelle"; // default

public String getSelectedTermine() { 
    return selectedTermine; 
}

public void setSelectedTermine(String value) {
    this.selectedTermine = value;
    // automatically keeps your 3 booleans in sync
    this.aktuelleTermine    = "aktuelle".equals(value);
    this.zukuenftigeTermine = "zukuenftige".equals(value);
    this.erledigteTermine   = "erledigte".equals(value);
}
SELECT s.name AS SchemaName, t.name AS TableName
FROM sys.tables t
INNER JOIN sys.schemas s ON t.schema_id = s.schema_id;
