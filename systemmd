 <h:outputScript>
        function resizeWindowOnLoad() {
            if (!#{archivierenVC.archivierenModell.upload}) {
                resizeArchivierenWindow();
            }
        }
        window.addEventListener('load', resizeWindowOnLoad);
    </h:outputScript>

    <p:dialog id="archivierungausgefuehrt"
              widgetVar="archivierungausgefuehrt"
              header="IMS: Hinweis"
              modal="true"
              closable="false"
              width="280">
        <h:panelGrid columns="1" style="text-align:center;">
            <h:outputText value="Das Dokument wurde archiviert." />
            <p:spacer height="20" />
            <p:commandButton value="OK"
                             action="#{archivierenVC.beendenFenster}"
                             process="@this"
                             update="@none" />
        </h:panelGrid>
    </p:dialog>
