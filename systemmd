<p:dialog id="orbexistiertnicht"
          widgetVar="orbexistiertnicht"
          header="IMS"
          modal="true"
          closable="false"
          width="280">
    <h:panelGrid columns="1" style="text-align:center;">
        <h:outputText value="#{archivierenVC.archivierenModell.errorORBMessage}" />
        <p:spacer height="20" />
        <h:panelGrid columns="3" style="text-align:center;">
            <p:commandButton value="OK"
                             style="width:100px;"
                             action="#{archivierenVC.errorORBAnlegen}"
                             process="@this"
                             update="@none" />
            <p:spacer width="15" />
            <p:commandButton value="Abbrechen"
                             style="width:100px;"
                             action="#{archivierenVC.errorORBAbbrechen}"
                             process="@this"
                             update="@none" />
        </h:panelGrid>
    </h:panelGrid>
</p:dialog>

