package de.deltalloyd.partnerdb.rest.DTO;

import jakarta.xml.bind.annotation.XmlRootElement;
import jakarta.xml.bind.annotation.XmlAccessType;
import jakarta.xml.bind.annotation.XmlAccessorType;

/**
 * DTO for sucheOrdnungsbegriffService and sucheOrdnungsbegriffServiceFull.
 * Both methods share identical parameters so one DTO covers both endpoints.
 */
@XmlRootElement(name = "sucheOrdnungsbegriff")
@XmlAccessorType(XmlAccessType.FIELD)
public class SucheOrdnungsbegriffDto {

    private String authToken;
    private String orbArtSchluessel;
    private String funkArtSchluessel;
    private Integer aMandant;
    private String aParameter;

    public SucheOrdnungsbegriffDto() {}

    public String getAuthToken() { return authToken; }
    public void setAuthToken(String authToken) { this.authToken = authToken; }

    public String getOrbArtSchluessel() { return orbArtSchluessel; }
    public void setOrbArtSchluessel(String orbArtSchluessel) { this.orbArtSchluessel = orbArtSchluessel; }

    public String getFunkArtSchluessel() { return funkArtSchluessel; }
    public void setFunkArtSchluessel(String funkArtSchluessel) { this.funkArtSchluessel = funkArtSchluessel; }

    public Integer getaMandant() { return aMandant; }
    public void setaMandant(Integer aMandant) { this.aMandant = aMandant; }

    public String getaParameter() { return aParameter; }
    public void setaParameter(String aParameter) { this.aParameter = aParameter; }
}
