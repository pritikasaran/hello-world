<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN"
        "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml"
    xmlns:h="http://java.sun.com/jsf/html"
    xmlns:f="http://java.sun.com/jsf/core"
    xmlns:ui="http://java.sun.com/jsf/facelets"
    xmlns:p="http://primefaces.org/ui">
<body>
    <ui:composition template="/templates/mainTemplateWithoutForm.xhtml">
        <ui:define name="content">
            <f:event type="javax.faces.event.PreRenderViewEvent"
                listener="#{archivierenVC.preRenderView}" />

            <h:form id="mainForm" enctype="#{archivierenVC.archivierenModell.upload ? 'multipart/form-data' : 'application/x-www-form-urlencoded'}">

                <h:outputScript>
                    function resizeWindowOnLoad() {
                        if (#{!archivierenVC.archivierenModell.upload}) {
                            resizeArchivierenWindow();
                        }
                    }
                    window.addEventListener('load', resizeWindowOnLoad);
                </h:outputScript>

                <!-- Popup: Archivierung ausgeführt -->
                <p:dialog id="archivierungausgefuehrt"
                    widgetVar="archivierungausgefuehrtDlg"
                    binding="#{archivierenVC.schliesseFensterPopup}"
                    closable="false"
                    modal="true"
                    style="width:280px;"
                    header="IMS:Hinweis">
                    <p:panelGrid columns="1" style="text-align:center;">
                        <h:outputFormat value="Das Dokument wurde archiviert." />
                        <p:spacer height="20" />
                        <p:commandButton value="OK"
                            action="#{archivierenVC.beendenFenster}" />
                    </p:panelGrid>
                </p:dialog>

                <!-- Popup: ORB existiert nicht -->
                <p:dialog id="orbexistiertnicht"
                    widgetVar="orbExistiertNichtDlg"
                    binding="#{archivierenVC.orbExistiertNichtFensterPopup}"
                    closable="true"
                    modal="true"
                    style="width:280px;"
                    header="IMS">
                    <p:panelGrid columns="1" style="text-align:center;">
                        <h:outputFormat value="#{archivierenVC.archivierenModell.errorORBMessage}" />
                        <p:spacer height="20" />
                        <p:panelGrid columns="3">
                            <p:commandButton value="OK" style="width:100px;"
                                action="#{archivierenVC.errorORBAnlegen}" />
                            <p:spacer width="15" />
                            <p:commandButton value="Abbrechen" style="width:100px;"
                                action="#{archivierenVC.errorORBAbrechen}" />
                        </p:panelGrid>
                    </p:panelGrid>
                </p:dialog>

                <!-- Fenster konnte nicht geschlossen werden -->
                <h:panelGroup rendered="#{archivierenVC.fensterSchliessen}">
                    <p:panelGrid columns="1">
                        <h:outputLabel style="font-weight:bold;"
                            value="Hinweis: Das Fenster konnte nicht automatisch geschlossen werden. Bitte schliessen Sie es manuell." />
                    </p:panelGrid>
                </h:panelGroup>

                <!-- Fehler beim Aufbau der Seite -->
                <h:panelGroup rendered="#{archivierenVC.invalidMailParams and !archivierenVC.fensterSchliessen}">
                    <h:outputScript>function fensterSchliessen() { window.close(); }</h:outputScript>
                    <p:panelGrid columns="1">
                        <h:outputLabel style="font-weight:bold;"
                            value="Beim Aufbau der Seite ist ein Fehler aufgetreten." />
                    </p:panelGrid>
                    <p:spacer height="25" />
                    <p:panelGrid columns="3">
                        <h:outputLabel style="font-weight:bold;"
                            value="Beschreibung:" />
                        <p:spacer width="15" />
                        <h:outputLabel
                            value="#{archivierenVC.archivierenModell.errorMessage}" />
                    </p:panelGrid>
                    <p:spacer height="25" />
                    <p:commandButton value="ok" onclick="fensterSchliessen(); return false;" />
                </h:panelGroup>

                <!-- Nur für die Archivierung von Emails -->
                <h:panelGroup rendered="#{!archivierenVC.fensterSchliessen and not archivierenVC.invalidMailParams}">

                    <div id="page">
                        <p:spacer height="15" />
                        <div id="main">

                        <p:panelGrid columns="7" cellspacing="10" cellpadding="4" columnClasses="col1,col2,col3,col4,col5,col6,col7">

                            <!-- Row 1: Mandant / ORB-Art / ORB -->
                            <p:row>
                                <p:column colspan="6">
                                    <p:panelGroup layout="block"
                                        style="#{archivierenVC.archivierenModell.upload ? 'display:none' : ''}">
                                        <p:selectOneMenu id="selMandant"
                                            styleClass="imsfieldsmall"
                                            immediate="true"
                                            value="#{archivierenVC.archivierenModell.mandant}"
                                            valueChangeListener="#{archivierenVC.mandantValueChangeListener}">
                                            <f:ajax execute="@this" render="@form" />
                                            <f:selectItems value="#{archivierenVC.archivierenModell.mandantItems}" />
                                            <p:ajax event="change" listener="#{archivierenVC.mandantValueChangeListener}" update="@form" />
                                        </p:selectOneMenu>
                                        <h:outputLabel value="Mandant:" for="selMandant" style="margin-right:5px;" />
                                        <p:spacer width="15" />
                                        <h:outputLabel value="ORB-Art:" for="selOrbart" style="margin-right:5px;" />
                                        <p:selectOneMenu id="selOrbart"
                                            styleClass="imsfieldsmall"
                                            immediate="true"
                                            value="#{archivierenVC.archivierenModell.orbArt}"
                                            valueChangeListener="#{archivierenVC.orbArtValueChangeListener}">
                                            <p:ajax event="change" listener="#{archivierenVC.orbArtValueChangeListener}" update="@form" />
                                            <f:selectItems value="#{archivierenVC.archivierenModell.orbartItems}" />
                                        </p:selectOneMenu>
                                        <p:spacer width="15" />
                                        <p:inputText id="inpOrb"
                                            label="ORB:"
                                            maxlength="24"
                                            style="width:120px;"
                                            styleClass="imsfieldsmall"
                                            value="#{archivierenVC.archivierenModell.orb}">
                                            <p:ajax event="change" update="@form" />
                                        </p:inputText>
                                        <h:outputLabel value="ORB:" for="inpOrb" />
                                    </p:panelGroup>
                                </p:column>
                                <p:column>
                                    <!-- commented out in original:
                                    <p:panelGroup rendered="#{!archivierenVC.archivierenModell.upload}">
                                        <p:selectBooleanCheckbox id="selNurAnhaenge"
                                            value="#{archivierenVC.archivierenModell.nurAnhaenge}"/>
                                        <p:spacer width="15" />
                                        <h:outputLabel value="Nur Anhänge"/>
                                    </p:panelGroup>
                                    -->
                                </p:column>
                            </p:row>

                            <!-- Row 2: Datei-Upload -->
                            <p:row>
                                <p:column colspan="7">
                                    <p:panelGroup layout="block"
                                        rendered="#{archivierenVC.archivierenModell.upload}">
                                        <h:outputLabel value="Dokument:" />
                                        <h:inputFile id="file" size="75"
                                            rendered="#{archivierenVC.renderInputFile}"
                                            value="#{archivierenVC.archivierenModell.file}" />
                                        <h:outputText value="#{archivierenVC.archivierenModell.fileName}" />
                                        <p:spacer width="5" />
                                        <p:commandButton value="Datei löschen" id="cmdDateiLoeschen"
                                            rendered="#{!archivierenVC.renderInputFile}"
                                            action="#{archivierenVC.dateiLoeschen}" />
                                    </p:panelGroup>
                                </p:column>
                            </p:row>

                            <!-- Separator -->
                            <p:row>
                                <p:column colspan="7">
                                    <p:spacer height="6" />
                                </p:column>
                            </p:row>
                            <p:row>
                                <p:column colspan="7">
                                    <p:separator />
                                </p:column>
                            </p:row>
                            <p:row>
                                <p:column colspan="7">
                                    <p:spacer height="6" />
                                </p:column>
                            </p:row>

                            <!-- Row 3: VgNr / Neuen Vorgang anlegen / Vorgangsart -->
                            <p:row>
                                <p:column colspan="2">
                                    <p:inputText id="mailVgNrAnzeigeId"
                                        label="VgNr:"
                                        style="width:58px;"
                                        maxlength="4"
                                        immediate="true"
                                        disabled="#{archivierenVC.archivierenModell.neuenVorgangAnlegen}"
                                        validator="#{archivierenVC.validateVgNr}"
                                        valueChangeListener="#{archivierenVC.vgNrValueChangeListener}"
                                        value="#{archivierenVC.archivierenModell.vgNummer}">
                                        <p:ajax event="change" update="@form" />
                                    </p:inputText>
                                    <h:outputLabel value="VgNr:" for="mailVgNrAnzeigeId" />
                                </p:column>
                                <p:column>
                                    <p:selectBooleanCheckbox id="selectVorgangAnlegen"
                                        immediate="true"
                                        valueChangeListener="#{archivierenVC.neueVorgangValueChangeListener}"
                                        value="#{archivierenVC.archivierenModell.neuenVorgangAnlegen}">
                                        <p:ajax event="change" update="@form" />
                                    </p:selectBooleanCheckbox>
                                </p:column>
                                <p:column>
                                    <h:outputLabel value="Neuen Vorgang anlegen:" for="mailNeuVgId" />
                                </p:column>
                                <p:column colspan="2">
                                    <h:outputLabel value="Vorgangsart:" for="mailVgArtId" />
                                </p:column>
                                <p:column>
                                    <p:selectOneMenu id="mailVgArtId"
                                        styleClass="imsfieldlarge"
                                        immediate="true"
                                        disabled="#{!archivierenVC.archivierenModell.neuenVorgangAnlegen}"
                                        value="#{archivierenVC.archivierenModell.vgArt}"
                                        valueChangeListener="#{archivierenVC.vgArtValueChangeListener}">
                                        <p:ajax event="change" update="@form" />
                                        <f:selectItems value="#{archivierenVC.archivierenModell.vgArtItems}" />
                                    </p:selectOneMenu>
                                </p:column>
                            </p:row>

                            <!-- Separator -->
                            <p:row>
                                <p:column colspan="7">
                                    <p:spacer height="6" />
                                </p:column>
                            </p:row>
                            <p:row>
                                <p:column colspan="7">
                                    <p:separator />
                                </p:column>
                            </p:row>
                            <p:row>
                                <p:column colspan="7">
                                    <p:spacer height="6" />
                                </p:column>
                            </p:row>

                            <!-- Row 4: Eingangsdatum / Dokumentenklasse -->
                            <p:row>
                                <p:column colspan="2">
                                    <h:outputLabel value="Eingangsdatum:" for="inpEingangsDatum" />
                                </p:column>
                                <p:column colspan="2">
                                    <p:calendar id="inpEingangsDatum"
                                        styleClass="datumfeld"
                                        value="#{archivierenVC.archivierenModell.eintragDatum}">
                                        <f:validateBean />
                                        <!-- original: validateDateTimeRange maximum="#{archivierenVC.eingangsdatumMaxDate}" -->
                                        <f:validator validatorId="primefaces.Future" />
                                        <p:ajax event="dateSelect" update="@form" />
                                    </p:calendar>
                                </p:column>
                                <p:column colspan="2">
                                    <h:outputLabel value="Dokumentenklasse:" />
                                </p:column>
                                <p:column>
                                    <p:selectOneMenu id="selDokukl"
                                        styleClass="imsfieldlarge"
                                        immediate="true"
                                        value="#{archivierenVC.archivierenModell.eintragDokuKl}"
                                        valueChangeListener="#{archivierenVC.dokuKlValueChangeMethod}">
                                        <p:ajax event="change" update="@form" />
                                        <f:selectItems value="#{archivierenVC.archivierenModell.eintragDokuKlItems}" />
                                    </p:selectOneMenu>
                                </p:column>
                            </p:row>

                            <!-- Row 5: Textkurzverweis / Anlassgeber -->
                            <p:row>
                                <p:column colspan="2">
                                    <h:outputLabel value="Textkurzverweis:" id="textkvKurzBez" />
                                </p:column>
                                <p:column colspan="2">
                                    <p:selectOneMenu id="selTkv"
                                        styleClass="imsfieldmedium"
                                        immediate="true"
                                        value="#{archivierenVC.archivierenModell.eintragTextkurzverweis}"
                                        valueChangeListener="#{archivierenVC.eintragTextkurzverweisChangeMethod}">
                                        <p:ajax event="change" update="@form" />
                                        <f:selectItems value="#{archivierenVC.archivierenModell.eintragTextkvItems}" />
                                    </p:selectOneMenu>
                                </p:column>
                                <p:column colspan="2">
                                    <h:outputLabel value="Anlassgeber/Empfänger:" />
                                </p:column>
                                <p:column>
                                    <p:selectOneMenu id="selAnlassgeber"
                                        styleClass="imsfieldlarge"
                                        immediate="true"
                                        value="#{archivierenVC.archivierenModell.eintragAnlassgeber}"
                                        valueChangeListener="#{archivierenVC.eintragAnlassgeberChangeMethod}">
                                        <p:ajax event="change" update="@form" />
                                        <f:selectItems value="#{archivierenVC.archivierenModell.eintragAnlassgeberItems}" />
                                    </p:selectOneMenu>
                                </p:column>
                            </p:row>

                            <!-- Row 6: Medium / Berechtigung Dokument -->
                            <p:row>
                                <p:column colspan="2">
                                    <h:outputLabel value="Medium:" />
                                </p:column>
                                <p:column colspan="2">
                                    <p:selectOneMenu id="selMedium"
                                        styleClass="imsfieldmedium"
                                        immediate="true"
                                        value="#{archivierenVC.archivierenModell.eintragMedium}"
                                        valueChangeListener="#{archivierenVC.eintragMediumChangeMethod}">
                                        <p:ajax event="change" update="@form" />
                                        <f:selectItems value="#{archivierenVC.archivierenModell.mediumItems}" />
                                    </p:selectOneMenu>
                                </p:column>
                                <p:column colspan="2">
                                    <h:outputLabel value="Berechtigung Dokument:" />
                                </p:column>
                                <p:column>
                                    <p:selectOneMenu id="selBerechtigungDok"
                                        styleClass="imsfieldlarge"
                                        immediate="true"
                                        value="#{archivierenVC.archivierenModell.eintragBerechtigungDok}"
                                        valueChangeListener="#{archivierenVC.eintragBerechtigungDokChangeMethod}">
                                        <p:ajax event="change" update="@form" />
                                        <f:selectItems value="#{archivierenVC.archivierenModell.eintragBerechtigungItems}" />
                                    </p:selectOneMenu>
                                </p:column>
                            </p:row>

                            <!-- Row 7 + 8: IndividuellerText (rowspan 2) -->
                            <p:row>
                                <p:column colspan="2">
                                    <h:outputLabel value="IndividuellerText:" />
                                </p:column>
                                <p:column colspan="5" rowspan="2">
                                    <p:inputTextarea id="txtIndivText"
                                        cols="85" rows="3" maxlength="200"
                                        styleClass="imsfieldlarge"
                                        value="#{archivierenVC.archivierenModell.indivText}" />
                                </p:column>
                            </p:row>
                            <p:row>
                                <p:column colspan="2">
                                    <h:outputLabel value="(max. 200 Zeichen)" />
                                </p:column>
                            </p:row>

                            <!-- Separator -->
                            <p:row>
                                <p:column colspan="7">
                                    <p:spacer height="6" />
                                </p:column>
                            </p:row>
                            <p:row>
                                <p:column colspan="7">
                                    <p:separator />
                                </p:column>
                            </p:row>
                            <p:row>
                                <p:column colspan="7">
                                    <p:spacer height="6" />
                                </p:column>
                            </p:row>

                            <!-- Row: Termin erzeugen / Termindatum / Abteilung -->
                            <p:row>
                                <p:column>
                                    <p:selectBooleanCheckbox id="selectTerminErzeugen"
                                        immediate="true"
                                        value="#{archivierenVC.archivierenModell.terminErzeugen}">
                                        <p:ajax event="change" update="@form" />
                                    </p:selectBooleanCheckbox>
                                </p:column>
                                <p:column style="white-space:nowrap;">
                                    <h:outputLabel value="Termin erzeugen:" for="selectTerminErzeugen" />
                                </p:column>
                                <p:column colspan="2">
                                    <h:outputLabel value="Termindatum:" for="inpTerminDatum" />
                                    <p:calendar id="inpTerminDatum"
                                        styleClass="datumfeld"
                                        value="#{archivierenVC.archivierenModell.terminDatum}"
                                        disabled="#{!archivierenVC.archivierenModell.terminErzeugen}">
                                        <!-- original: validateDateTimeRange minimum="#{archivierenVC.minimumDate}" -->
                                        <p:ajax event="dateSelect" update="@form" />
                                    </p:calendar>
                                </p:column>
                                <p:column colspan="2">
                                    <h:outputLabel value="Abteilung:" for="inpAbtlg" />
                                </p:column>
                                <p:column>
                                    <p:inputText id="inpAbtlg"
                                        styleClass="imsfieldsmall"
                                        value="#{archivierenVC.archivierenModell.terminAbteilung}"
                                        disabled="#{!archivierenVC.archivierenModell.terminErzeugen}" />
                                </p:column>
                            </p:row>

                            <!-- Row: Terminart / Gruppe -->
                            <p:row>
                                <p:column colspan="2">
                                    <h:outputLabel value="Terminart:" for="selTerminArt" />
                                </p:column>
                                <p:column colspan="2">
                                    <p:selectOneMenu id="selTerminArt"
                                        styleClass="imsfieldmedium"
                                        immediate="true"
                                        disabled="#{!archivierenVC.archivierenModell.terminErzeugen}"
                                        valueChangeListener="#{archivierenVC.terminartValueChangeMethod}"
                                        value="#{archivierenVC.archivierenModell.terminArt}">
                                        <p:ajax event="change" update="@form" />
                                        <f:selectItems value="#{archivierenVC.archivierenModell.terminArtItems}" />
                                    </p:selectOneMenu>
                                </p:column>
                                <p:column colspan="2">
                                    <h:outputLabel value="Gruppe:" for="inpGrp" />
                                </p:column>
                                <p:column>
                                    <p:inputText id="inpGrp"
                                        styleClass="imsfieldsmall"
                                        value="#{archivierenVC.archivierenModell.terminGruppe}"
                                        disabled="#{!archivierenVC.archivierenModell.terminErzeugen}" />
                                </p:column>
                            </p:row>

                            <!-- Row: Termingrund / Diktat-Kz -->
                            <p:row>
                                <p:column colspan="2">
                                    <h:outputLabel value="Termingrund:" for="selTermingrund" />
                                </p:column>
                                <p:column colspan="2">
                                    <p:selectOneMenu id="selTermingrund"
                                        styleClass="imsfieldmedium"
                                        immediate="true"
                                        disabled="#{!archivierenVC.archivierenModell.terminErzeugen}"
                                        value="#{archivierenVC.archivierenModell.termingrund}"
                                        valueChangeListener="#{archivierenVC.termingrundValueChangeMethod}">
                                        <p:ajax event="change" update="@form" />
                                        <f:selectItems value="#{archivierenVC.archivierenModell.terminGrundItems}" />
                                    </p:selectOneMenu>
                                </p:column>
                                <p:column colspan="2">
                                    <h:outputLabel value="Diktat-Kz:" for="inpDikKz" />
                                </p:column>
                                <p:column>
                                    <p:inputText id="inpDikKz"
                                        styleClass="imsfieldsmall"
                                        value="#{archivierenVC.archivierenModell.terminDiktatKz}"
                                        disabled="#{!archivierenVC.archivierenModell.terminErzeugen}" />
                                </p:column>
                            </p:row>

                            <!-- Separator -->
                            <p:row>
                                <p:column colspan="7">
                                    <p:spacer height="6" />
                                </p:column>
                            </p:row>
                            <p:row>
                                <p:column colspan="7">
                                    <p:separator />
                                </p:column>
                            </p:row>
                            <p:row>
                                <p:column colspan="7">
                                    <p:spacer height="6" />
                                </p:column>
                            </p:row>

                            <!-- Row: Kopieren zu weiteren Ordnungsbegriffen / Termine erzeugen -->
                            <p:row>
                                <p:column>
                                    <p:selectBooleanCheckbox id="selectKopiereZuOrb"
                                        immediate="true"
                                        value="#{archivierenVC.archivierenModell.kopiereZuOrb}"
                                        valueChangeListener="#{archivierenVC.kopierenZuWeiterenORB}"
                                        disabled="#{archivierenVC.archivierenModell.serienBrief}">
                                        <p:ajax event="change" update="@form" />
                                    </p:selectBooleanCheckbox>
                                </p:column>
                                <p:column colspan="3">
                                    <h:outputLabel value="Kopieren zu weiteren Ordnungsbegriffen" />
                                </p:column>
                                <p:column colspan="3">
                                    <p:panelGrid columns="3">
                                        <p:selectBooleanCheckbox id="selectTermineErzeugen"
                                            value="#{archivierenVC.archivierenModell.termineErzeugen}"
                                            disabled="#{(!archivierenVC.archivierenModell.terminErzeugen) || (!archivierenVC.archivierenModell.kopiereZuOrb) || (archivierenVC.archivierenModell.serienBrief)}" />
                                        <p:spacer width="15" />
                                        <h:outputLabel value="Termine erzeugen" />
                                    </p:panelGrid>
                                </p:column>
                            </p:row>

                            <!-- Row: ORB-Table (rowspan 7) + right-side fields -->
                            <p:row>
                                <p:column colspan="4" rowspan="7">
                                    <p:dataTable id="zielTable"
                                        styleClass="imsORBTable"
                                        value="#{archivierenVC.archivierenModell.zielList}"
                                        rowKey="#{zielItem.orb}"
                                        selection="#{archivierenVC.archivierenModell.zielRowKeySet}"
                                        selectionMode="single"
                                        var="zielItem"
                                        lazy="false"
                                        emptyMessage="Keine Dokumente ausgewählt.">
                                        <p:column headerText="MA" style="width:45px;" styleClass="imsTableData">
                                            <h:outputText value="#{zielItem.mandant}" />
                                        </p:column>
                                        <p:column headerText="ORB-Art" style="width:140px;" styleClass="imsTableData">
                                            <h:outputText value="#{zielItem.orbArt}" />
                                        </p:column>
                                        <p:column headerText="ORB" style="width:140px;" styleClass="imsTableData">
                                            <h:outputText value="#{zielItem.orb}" />
                                        </p:column>
                                        <p:column headerText="VG-Nr" style="width:65px;" styleClass="imsTableData">
                                            <h:outputText value="#{zielItem.vgNr}" />
                                        </p:column>
                                    </p:dataTable>
                                </p:column>
                            </p:row>

                            <!-- Row: Mandant (Umb) -->
                            <p:row>
                                <p:column colspan="2">
                                    <h:outputLabel value="Mandant:" for="selMandantUmb" />
                                </p:column>
                                <p:column>
                                    <p:selectOneMenu id="selMandantUmb"
                                        styleClass="imsfieldsmall"
                                        immediate="true"
                                        disabled="#{!archivierenVC.archivierenModell.kopiereZuOrb}"
                                        value="#{archivierenVC.archivierenModell.umbAktuellerEintrag.mandant}"
                                        valueChangeListener="#{archivierenVC.mandantUmbChangeMethod}">
                                        <p:ajax event="change" update="@form" />
                                        <f:selectItems value="#{archivierenVC.archivierenModell.umbMandantItems}" />
                                    </p:selectOneMenu>
                                </p:column>
                            </p:row>

                            <!-- Row: ORB-Art (Umb) -->
                            <p:row>
                                <p:column colspan="2">
                                    <h:outputLabel value="ORB-Art:" for="selOrbartUmb" />
                                </p:column>
                                <p:column>
                                    <p:selectOneMenu id="selOrbartUmb"
                                        styleClass="imsfieldsmall"
                                        immediate="true"
                                        value="#{archivierenVC.archivierenModell.umbAktuellerEintrag.orbArt}"
                                        disabled="#{!archivierenVC.archivierenModell.kopiereZuOrb}"
                                        valueChangeListener="#{archivierenVC.orbartUmbChangeMethod}">
                                        <p:ajax event="change" update="@form" />
                                        <f:selectItems value="#{archivierenVC.archivierenModell.umbOrbartItems}" />
                                    </p:selectOneMenu>
                                </p:column>
                            </p:row>

                            <!-- Row: ORB (Umb) -->
                            <p:row>
                                <p:column colspan="2">
                                    <h:outputLabel value="ORB:" />
                                </p:column>
                                <p:column>
                                    <p:inputText id="selOrbUmb"
                                        style="width:125px;"
                                        disabled="#{!archivierenVC.archivierenModell.kopiereZuOrb}"
                                        value="#{archivierenVC.archivierenModell.umbAktuellerEintrag.orb}" />
                                </p:column>
                            </p:row>

                            <!-- Row: VG-Nr (Umb) -->
                            <p:row>
                                <p:column colspan="2">
                                    <h:outputLabel value="VG-Nr.:" />
                                </p:column>
                                <p:column>
                                    <p:inputText id="selVgNrUmb"
                                        style="width:55px;"
                                        disabled="#{!archivierenVC.archivierenModell.kopiereZuOrb}"
                                        value="#{archivierenVC.archivierenModell.umbAktuellerEintrag.vgNr}" />
                                </p:column>
                            </p:row>

                            <!-- Row: Hinzufügen / Löschen buttons -->
                            <p:row>
                                <p:column colspan="3" style="text-align:center;">
                                    <p:commandButton id="cmdHinzufuegen"
                                        disabled="#{!archivierenVC.archivierenModell.kopiereZuOrb}"
                                        title="Ziel hinzufügen"
                                        value="Hinzufügen"
                                        actionListener="#{archivierenVC.actionHinzufuegen}"
                                        update="@form" />
                                    <p:spacer width="10" />
                                    <p:commandButton id="cmdLoeschen"
                                        title="Ziel entfernen"
                                        disabled="#{!archivierenVC.archivierenModell.kopiereZuOrb}"
                                        value="Löschen"
                                        action="#{archivierenVC.removeRow}"
                                        update="@form" />
                                </p:column>
                            </p:row>

                            <!-- Row: Serienbrief (only rendered when upload=true) -->
                            <p:row rendered="#{archivierenVC.archivierenModell.upload}">
                                <p:column>
                                    <p:selectBooleanCheckbox id="selSerienbrief"
                                        immediate="true"
                                        disabled="#{archivierenVC.archivierenModell.kopiereZuOrb}"
                                        value="#{archivierenVC.archivierenModell.serienBrief}">
                                        <p:ajax event="change" update="@form" />
                                    </p:selectBooleanCheckbox>
                                </p:column>
                                <p:column>
                                    <h:outputLabel value="Serienbrief" />
                                </p:column>
                            </p:row>

                            <!-- Row: Statustext -->
                            <p:row>
                                <p:column colspan="7">
                                    <p:inputText id="statusText"
                                        style="width:750px;color:black;"
                                        disabled="true"
                                        value="#{archivierenVC.archivierenModell.statustext}" />
                                </p:column>
                            </p:row>

                            <!-- Row: Ausführen / Abbrechen -->
                            <p:row>
                                <p:column colspan="6" style="text-align:center;">
                                    <p:commandButton id="cmdArchivieren"
                                        title="Ausführen"
                                        value="Ausführen"
                                        actionListener="#{archivierenVC.archivierungAusfuehren}"
                                        update="@form" />
                                    <p:spacer width="10" />
                                    <p:commandButton id="cmdAbbrechen"
                                        title="Abbrechen"
                                        value="Abbrechen"
                                        actionListener="#{archivierenVC.archivierungAbbrechen}"
                                        update="@form" />
                                </p:column>
                            </p:row>

                        </p:panelGrid>

                        <!-- Popup: Sicherheitsabfrage -->
                        <p:dialog id="sicherheitsabfrage"
                            widgetVar="sicherheitsabfrageDlg"
                            binding="#{archivierenVC.sicherheitsabfragePopup}"
                            closable="true"
                            modal="true"
                            header="Sind Sie sicher?">
                            <p:panelGrid columns="1">
                                <h:outputFormat
                                    value="Der Ordnungsbegriff '#{archivierenVC.archivierenModell.umbAktuellerEintrag.orb}' existiert nicht! Soll er angelegt werden?" />
                                <p:spacer height="10" />
                                <p:panelGrid columns="3" style="text-align:center;">
                                    <p:commandButton id="cmdOk"
                                        value="OK"
                                        style="width:100px;"
                                        action="#{archivierenVC.fuegeZielHinzu}"
                                        update="@form" />
                                    <p:spacer width="15" />
                                    <p:commandButton id="cmdCancel"
                                        value="Abbrechen"
                                        style="width:100px;"
                                        action="#{archivierenVC.doNothing}" />
                                </p:panelGrid>
                            </p:panelGrid>
                        </p:dialog>

                        </div>
                    </div>

                    <p:messages />

                </h:panelGroup>

            </h:form>
        </ui:define>
        <ui:define name="footer">
        </ui:define>
    </ui:composition>
</body>
</html>
