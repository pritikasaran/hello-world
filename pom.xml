 <!-- Hinweistext (above the field, spanning both columns) -->
    <h:outputText value="#{kKEControllerMasch.kkeModel.hinweisText}"
                  styleClass="imsAnzeigeRotKlein"
                  colspan="2" />

    <!-- Anzahl Arbeitstage -->
    <h:outputLabel for="inpTage" value="Anzahl Arbeitstage:" />
    <p:inputText id="inpTage"
                 value="#{kKEControllerMasch.kkeModel.arbeitstage}"
                 required="true"
                 size="10" maxlength="10"
                 onfocus="selectContent(this)">
        <f:convertNumber locale="de" />
        <f:validator validatorId="KkeArbeitstagValidator" />
        <!-- Server-side listener equivalent -->
        <p:ajax event="change"
                listener="#{postkorbVC.aktualisierenListener}"
                update="@form" />
    </p:inputText>

    <!-- Hinweis Arbeitstage (spanning both columns) -->
    <h:outputText value="#{kKEControllerMasch.kkeModel.hinweisArbeitstage}"
                  styleClass="imsAnzeigeRotKlein"
                  colspan="2" />
