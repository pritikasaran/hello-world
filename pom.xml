package de.deltalloyd.partnerdb.rest.dto;

import jakarta.xml.bind.annotation.XmlAccessType;
import jakarta.xml.bind.annotation.XmlAccessorType;
import jakarta.xml.bind.annotation.XmlRootElement;

@XmlRootElement(name = "checkIfADMAOrbFuerAxaMaklerExists")
@XmlAccessorType(XmlAccessType.FIELD)
public class CheckADMAOrbRequestDto {

    private String authToken;
    private String admaSchluessel;

    public CheckADMAOrbRequestDto() {}

    public String getAuthToken() { return authToken; }
    public void setAuthToken(String authToken) { this.authToken = authToken; }

    public String getAdmaSchluessel() { return admaSchluessel; }
    public void setAdmaSchluessel(String admaSchluessel) { this.admaSchluessel = admaSchluessel; }
}
