<?xml version='1.0' encoding='UTF-8' ?>
<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN"
        "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<div xmlns:h="http://java.sun.com/jsf/html"
	xmlns:f="http://java.sun.com/jsf/core"
	xmlns:ui="http://java.sun.com/jsf/facelets"
	xmlns:af="http://xmlns.oracle.com/adf/faces/rich"
	xmlns:tr="http://myfaces.apache.org/trinidad"
	xmlns:trh="http://myfaces.apache.org/trinidad/html">
	
	  <af:menuBar>
        <af:menu text="BQM">
            <af:commandMenuItem text="Beschwerdebericht anzeigen" 
                action="${beschwUebersichtVC.beschwerdeAnzeigen}"
                icon="/resources/images/beschw_anzeigen.gif"/>
            <af:commandMenuItem text="Beschwerdebericht löschen" 
            	rendered="#{beschwUebersichtVC.bewerdeManager}"
            	partialSubmit="true"
                actionListener="#{beschwUebersichtVC.actionLoeschen}"
                icon="/resources/images/delete.gif"/>
    	</af:menu>
    	<af:menu text="Hilfe">
			<af:commandMenuItem text="Anzeige Handbuch IMS"
				windowModalityType="applicationModal" useWindow="true"
                windowWidth="750" windowHeight="900" partialSubmit="true"
				action="#{beschwUebersichtVC.openIMSHandbuch}"
				icon="/resources/images/information.gif" />
			<af:commandMenuItem text="Anzeige Handbuch KKE"
				windowModalityType="applicationModal" useWindow="true"
                windowWidth="750" windowHeight="900" partialSubmit="true"
				action="#{beschwUebersichtVC.openKKEHandbuch}"
				icon="/resources/images/information.gif" />
			<af:commandMenuItem text="Anzeige Handbuch BQM"
				windowModalityType="applicationModal" useWindow="true"
                windowWidth="750" windowHeight="900" partialSubmit="true"
				action="#{beschwUebersichtVC.openBQMHandbuch}"
				icon="/resources/images/information.gif" />
			<af:commandMenuItem text="Info"
				windowModalityType="applicationModal" useWindow="true"
				windowWidth="200" windowHeight="200" partialSubmit="true"
				action="#{beschwUebersichtVC.showInfo}"/>
		</af:menu>
    </af:menuBar>
    
    <ui:remove>Buttons</ui:remove>
	<af:panelFormLayout id="buttonBarAE" rows="1" fieldWidth="100%">
		<af:panelGroupLayout layout="horizontal" styleClass="AFStretchWidth">
			<af:panelGroupLayout layout="horizontal">
			 <af:commandButton id="cmdAktualisieren"
                	partialSubmit="true"
                    inlineStyle="padding-left:2px;padding-right:2px;"
                    icon="/resources/images/refresh.gif" shortDesc="Aktualisieren"
                    action="#{beschwUebersichtVC.aktualisieren}">
                </af:commandButton>
				<af:commandButton id="cmdBQMAnzeigen"
					icon="/resources/images/beschw_anzeigen.gif" 
					shortDesc="Beschwerdebericht anzeigen"
					inlineStyle="padding-left:2px;padding-right:2px;"
					action="#{beschwUebersichtVC.beschwerdeAnzeigen}">
					<f:ajax execute="@this" render="@form" />
				</af:commandButton>
				<af:commandButton id="cmdBQMLoeschen"
					partialSubmit="true"
					icon="/resources/images/delete.gif" 
					shortDesc="Beschwerdebericht löschen"
					inlineStyle="padding-left:2px;padding-right:2px;"
					rendered="#{beschwUebersichtVC.bewerdeManager}" 
					actionListener="#{beschwUebersichtVC.actionLoeschen}"/>
			</af:panelGroupLayout>
			
			<af:panelGroupLayout layout="horizontal" halign="right">
				<af:commandButton icon="/resources/images/akteschliessen.gif" 
					inlineStyle="padding-left:2px;padding-right:2px;"
					id="cmdAkteVerlassen" accessKey="V" shortDesc="Beschwerdeübersicht schlie&#223;en"
					action="#{beschwUebersichtVC.schliessen}">
				</af:commandButton>
			</af:panelGroupLayout>
		</af:panelGroupLayout>
	</af:panelFormLayout>
			
	<tr:panelCaptionGroup captionText="Filter">
		<af:panelGroupLayout layout="horizontal">
			<af:outputLabel value="Jahr:"/>
			<af:selectOneChoice id="selJahr" immediate="true" autoSubmit="true"
				value="#{beschwUebersichtVC.beschwUebersichtModell.filter.jahr}">
				<f:selectItems id="jahrItems"
					value="#{beschwUebersichtVC.beschwUebersichtModell.jahrItems}"/>
			</af:selectOneChoice>
			
			<af:outputLabel value="Status:"/>
			<af:selectOneChoice id="selStatus" immediate="true" autoSubmit="true"
				value="#{beschwUebersichtVC.beschwUebersichtModell.filter.status}">
				<f:selectItems id="statusItems"
					value="#{beschwUebersichtVC.beschwUebersichtModell.statusItems}"/>
			</af:selectOneChoice>
			
			<af:outputLabel value="Art:"/>
			<af:selectOneChoice id="selArt" immediate="true" autoSubmit="true"
				value="#{beschwUebersichtVC.beschwUebersichtModell.filter.art}">
				<f:selectItems id="artItems"
					value="#{beschwUebersichtVC.beschwUebersichtModell.artItems}"/>
			</af:selectOneChoice>
			
			<af:outputLabel value="Bereich:"/>
			<af:selectOneChoice id="selBereich" immediate="true" autoSubmit="true"
				value="#{beschwUebersichtVC.beschwUebersichtModell.filter.bereich}">
				<f:selectItems id="bereichItems"
					value="#{beschwUebersichtVC.beschwUebersichtModell.bereichItems}"/>
			</af:selectOneChoice>
		</af:panelGroupLayout>
	</tr:panelCaptionGroup>
	
	 <af:spacer height="10pt"/>
			
	<af:panelGroupLayout layout="vertical">
	<af:table id="tabAlleEintraege" var="eintrag" 
		rowSelection="single" inlineStyle="height:#{beschwUebersichtVC.beschwUebersichtModell.heightTable}px;"
		value="#{beschwUebersichtVC.beschwUebersichtModell.beschwerden}"
		rowBandingInterval="0" emptyText="Keine Eintr&#228;ge vorhanden."
		selectedRowKeys="#{beschwUebersichtVC.beschwUebersichtModell.eintraegeRowKeySet}"
		selectionListener="#{beschwUebersichtVC.selectEintraege}"
		styleClass="AFStretchWidth"
		binding="#{beschwUebersichtVC.eintraegeTable}"
		displayRow="selected" contentDelivery="immediate" 
		fetchSize="#{beschwUebersichtVC.fetchSizeTable}"
				disableColumnReordering="true">
				
		<af:clientListener type="dblClick" method="dblClickBeschwerde" />
		<af:clientListener type="load" method="rewriteAdfSetFocusOnEditableElementInNode" />
		<af:column headerText="Jahr" noWrap="true" sortProperty="jahr"
			sortable="false" width="50px" headerClass="imsTableHeader"
			styleClass="imsTableData">
			<af:outputText value="#{eintrag.eingangDat}" converter="JahrConverter"/>
		</af:column>
		<af:column headerText="Nummer" noWrap="true" sortProperty="nummer"
			sortable="false" width="80px" headerClass="imsTableHeader"
			styleClass="imsTableData">
			<af:outputText value="#{eintrag.nummer}"/>
		</af:column>
		<af:column headerText="Eingang" sortProperty="eingangDat"
			sortable="false" headerNoWrap="true" noWrap="true" width="105px"
			headerClass="imsTableHeader" styleClass="imsTableData">
			<af:outputFormatted value="#{eintrag.eingangDat}" converter="DatumKurz" />
		</af:column>
		<af:column headerText="Art" noWrap="true"
			sortProperty="art" sortable="false"
			headerClass="imsTableHeader" styleClass="imsTableData" width="155px">
			<af:outputText value="#{eintrag.beschwArtKurzText}"
				shortDesc="#{eintrag.beschwArtSchl}: #{eintrag.beschwArtLangText}" />
		</af:column>
		<af:column headerText="Status" sortProperty="status"
			sortable="false" headerNoWrap="true" noWrap="true" width="65px"
			headerClass="imsTableHeader" styleClass="imsTableData">
			<af:outputText value="#{eintrag.beschwStatusKurzText}"
				shortDesc="#{eintrag.beschwStatus}: #{eintrag.beschwStatusLangText}" />
		</af:column>
		<af:column headerText="Bearbeiter" noWrap="true" sortProperty="bearbeiter"
			sortable="false" headerClass="imsTableHeader"
			styleClass="imsTableData" width="100px">
			<af:outputText value="#{eintrag.verantwortlKurzText}"
				shortDesc="#{eintrag.verantwortlUserid}: #{eintrag.verantwortlName}" />
		</af:column>
		<af:column headerText="MA" noWrap="true"
			sortProperty="mandant" sortable="false" width="54px"
			headerClass="imsTableHeader" styleClass="imsTableData">
			<af:outputText value="#{eintrag.mandantKurzText}" 
				shortDesc="#{eintrag.mandant}: #{eintrag.mandantLangText}"/>
		</af:column>
		<af:column headerText="ORB-Art" noWrap="true"
			sortProperty="orbart" sortable="false" width="70px"
			headerClass="imsTableHeader" styleClass="imsTableData">
			<af:outputText value="#{eintrag.orbartKurzText}" 
				shortDesc="#{eintrag.orbart}: #{eintrag.orbartLangText}"/>
		</af:column>
		<af:column headerText="ORB" noWrap="true"
			sortProperty="orb" sortable="false" width="120px"
			headerClass="imsTableHeader" styleClass="imsTableData">
			<af:outputText value="#{eintrag.orb}" />
		</af:column>
		<af:column headerText="Erfasser" noWrap="true" sortProperty="erfasser"
			sortable="false" headerClass="imsTableHeader"
			styleClass="imsTableData" width="100px">
			<af:outputText value="#{eintrag.erfasserKurzText}" 
				shortDesc="#{eintrag.erfasserUserid}: #{eintrag.erfasserName}"/>
		</af:column>
		<af:column headerText="Bereich" sortProperty="bereich" sortable="false"
			width="100px" headerClass="imsTableHeader" styleClass="imsTableData">
			<af:outputText value="#{eintrag.bereichKurzText}" 
				shortDesc="#{eintrag.bereichSchl}: #{eintrag.bereichLangText}" />
		</af:column>
	</af:table>
	</af:panelGroupLayout>
	
	 <af:popup id="sicherheitsabfrage" binding="#{beschwUebersichtVC.sicherheitsabfragePopup}">
         <af:dialog okVisible="false" cancelVisible="false" modal="true" title="Sind Sie sicher?">
                <af:panelGroupLayout layout="vertical">
                 <af:outputFormatted value="Der Beschwerdebericht Nr #{beschwUebersichtVC.beschwUebersichtModell.selBeschwerde.nummer} soll gelöscht werden?"/>
                 <af:panelGroupLayout layout="horizontal">
                    <af:commandButton text="Ja" action="#{beschwUebersichtVC.beschwerdeLoeschen}">
                    	<f:ajax execute="@this" render="@form" />
                    </af:commandButton>
                    	<af:commandButton text="Nein" action="#{beschwUebersichtVC.doNothing}">
                    <f:ajax execute="@this" render="@form" />
                    </af:commandButton>
                 </af:panelGroupLayout>
             </af:panelGroupLayout>
              
            </af:dialog>
        </af:popup>								
</div>
