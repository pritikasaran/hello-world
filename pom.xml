    <!-- Bearbeitung -->
    <h:outputLabel for="selBearb" value="Bearbeitung:" />
    <p:selectOneMenu id="selBearb"
                     value="#{kKEControllerMasch.kkeModel.bearbeitung}"
                     style="width:300px">
        <f:selectItems value="#{kKEControllerMasch.kkeModel.bearbItems}" />
    </p:selectOneMenu>

    <!-- Anzahl Einzelverträge (conditional rendering) -->
    <h:outputLabel for="selAnzalVtr" value="Anzahl Einzelverträge:"
                   rendered="#{kKEControllerMasch.kkeModel.kollOrbArt}" />
    <p:inputText id="selAnzalVtr"
                 value="#{kKEControllerMasch.kkeModel.kollvtrAnzahl}"
                 rendered="#{kKEControllerMasch.kkeModel.kollOrbArt}"
                 size="10" maxlength="10"
                 onfocus="selectContent(this)" />
</p:panelGrid>

<!-- Action button -->
<p:commandButton id="kkeAusfuehren"
                 value="Ausführen"
                 actionListener="#{akteVC.kkeAusfuehrenListener}"
                 update="@form" />
