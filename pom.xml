<p:remoteCommand name="applySortierung"
                 action="#{postkorbVC.actionAktualisieren}"
                 update="postkorbTable"/>


public void speichern() {
    // save sort criteria to postkorbModell
    postkorbModell.setSortierKriterien(sortierungModell.getSortierKriterien());
    
    // close window and trigger reload in parent
    PrimeFaces.current().executeScript(
        "window.opener.applySortierung(); window.close();"
    );
}
