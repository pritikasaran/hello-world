package de.deltalloyd.partnerdb.rest.restWrapper;

import java.util.List;

import de.deltalloyd.partnerdb.core.type.AdresseTO;
import de.deltalloyd.partnerdb.core.type.BankVerbindungTO;
import de.deltalloyd.partnerdb.core.type.EinzelVsnrTO;
import de.deltalloyd.partnerdb.core.type.JournalEintragTO;
import de.deltalloyd.partnerdb.core.type.util.PartnerBilanzdaten;
import de.deltalloyd.partnerdb.rest.DTO.AddressDto;
import de.deltalloyd.partnerdb.rest.DTO.CreatePasswordDto;
import de.deltalloyd.partnerdb.rest.DTO.GetKopfDublettenAdressNrDto;
import de.deltalloyd.partnerdb.rest.DTO.GetKopfDublettenDto;
import de.deltalloyd.partnerdb.rest.DTO.GetNeusteEinzelVsnrDto;
import de.deltalloyd.partnerdb.rest.DTO.HoleFreiePartnerNummerDto;
import de.deltalloyd.partnerdb.rest.DTO.LadePartnerPostAdresseDto;
import de.deltalloyd.partnerdb.rest.DTO.PartnerLadeDto;
import de.deltalloyd.partnerdb.rest.DTO.PartnerSaveDto;
import de.deltalloyd.partnerdb.rest.DTO.PartnerbankLade;
import de.deltalloyd.partnerdb.rest.DTO.UpdateUebertragungBRSDto;
import de.deltalloyd.partnerdb.rest.DTO.ValidateAddressDto;
import de.deltalloyd.partnerdb.rest.DTO.ValidatePartnerDto;
import de.deltalloyd.partnerdb.rest.DTO.ValidiereBankverbindungDto;
import de.deltalloyd.partnerdb.rest.DTO.ValidierePartnerGrunddatenDto;
import de.deltalloyd.partnerdb.core.type.PartnerGrunddatenTO;
import de.deltalloyd.partnerdb.core.type.PartnerTO;
import de.deltalloyd.partnerdb.core.type.PostAdresseTO;
import de.deltalloyd.partnerdb.core.type.PostPruefAntwortTO;
import de.deltalloyd.partnerdb.core.type.ValidationResult;
import de.deltalloyd.partnerdb.webservices.impl.KksnWSImpl;
import de.deltalloyd.partnerdb.webservices.interfaces.IPartnerWebService;

import jakarta.enterprise.context.ApplicationScoped;
import jakarta.inject.Inject;
import jakarta.ws.rs.Consumes;
import jakarta.ws.rs.POST;
import jakarta.ws.rs.Path;
import jakarta.ws.rs.Produces;
import jakarta.ws.rs.core.MediaType;

@ApplicationScoped
@Path("/partnerWeb")
@Produces(MediaType.APPLICATION_XML)
@Consumes(MediaType.APPLICATION_XML)
public class RestApplication3 {

    @Inject
    IPartnerWebService partnerWebService;

    // -------------------------------------------------------------------------
    // Partner core CRUD
    // -------------------------------------------------------------------------

    /**
     * Load a partner by client + partner number.
     * POST because the request body carries auth token and multiple filter params.
     *
     * GET /partnerWeb/partners/load
     */
    @POST
    @Path("/partners/load")
    public PartnerTO ladePartner(PartnerLadeDto dto) throws Exception {
        return partnerWebService.ladePartner(
                dto.getAuthToken(),
                dto.isNebendubletteaufloesen(),
                dto.getKlient(),
                dto.getPartnernr(),
                dto.getParameter());
    }

    /**
     * Create a new partner.
     *
     * POST /partnerWeb/partners
     */
    @POST
    @Path("/partners")
    public ValidationResult erzeugePartner(ValidatePartnerDto dto) throws Exception {
        return partnerWebService.erzeugePartner(
                dto.getAuthToken(),
                dto.getPartnerTo(),
                dto.getaParameter());
    }

    /**
     * Update an existing partner.
     *
     * PUT /partnerWeb/partners
     */
    @POST
    @Path("/partners/update")
    public void aktualisierePartner(PartnerSaveDto dto) throws Exception {
        partnerWebService.aktualisierePartner(
                dto.getAuthToken(),
                dto.getPartnerTo(),
                dto.getaParameter());
    }

    // -------------------------------------------------------------------------
    // Partner sub-resources
    // -------------------------------------------------------------------------

    /**
     * Load the SAP information for a partner.
     *
     * POST /partnerWeb/partners/sap
     */
    @POST
    @Path("/partners/sap")
    public List<String[]> ladeSapPartnerInformation(PartnerLadeDto dto) throws Exception {
        return partnerWebService.ladeSapPartnerInformation(dto.getPartnernr().toString());
    }

    /**
     * Load the postal address of a partner.
     *
     * POST /partnerWeb/partners/address/load
     * (POST because auth token + multiple params are passed in the body)
     */
    @POST
    @Path("/partners/address/load")
    public PostAdresseTO ladePartnerPostAdresse(LadePartnerPostAdresseDto dto) throws Exception {
        return partnerWebService.ladePartnerPostAdresse(
                dto.getAuthToken(),
                dto.getKlient(),
                dto.getPartnernr(),
                dto.getaAnschrnr(),
                dto.getParameter());
    }

    /**
     * Load the bank connection of a partner.
     *
     * POST /partnerWeb/partners/bank/load
     */
    @POST
    @Path("/partners/bank/load")
    public BankVerbindungTO ladePartnerBankverbindung(PartnerbankLade dto) throws Exception {
        return partnerWebService.ladePartnerBankverbindung(
                dto.getAuthToken(),
                dto.getKlient(),
                dto.getPartnernr(),
                dto.getBankNr(),
                dto.getParameter());
    }

    /**
     * Load the journal entries for a partner.
     *
     * POST /partnerWeb/partners/journal/load
     */
    @POST
    @Path("/partners/journal/load")
    public List<JournalEintragTO> ladeJournalFuerPartner(PartnerLadeDto dto) throws Exception {
        return partnerWebService.ladeJournalFuerPartner(
                dto.getKlient(),
                dto.getKlient()); // NOTE: verify 2nd arg — likely partnernr in original
    }

    /**
     * Load SAP balance sheet data for a partner.
     *
     * POST /partnerWeb/partners/balance
     */
    @POST
    @Path("/partners/balance")
    public PartnerBilanzdaten getbilanzdaten(PartnerLadeDto dto) throws Exception {
        return partnerWebService.getbilanzdaten(dto.getKlient(), dto.getPartnernr());
    }

    /**
     * Get the latest Einzel-VSNR for a partner.
     *
     * POST /partnerWeb/partners/vsnr/latest
     */
    @POST
    @Path("/partners/vsnr/latest")
    public List<EinzelVsnrTO> getNeusteEinzelVsnr(GetNeusteEinzelVsnrDto dto) throws Exception {
        return partnerWebService.getNeusteEinzelVsnr(
                dto.getAuthToken(),
                dto.getMandant(),
                dto.getOrbart(),
                dto.getOrb());
    }

    /**
     * Create a password for a partner.
     *
     * POST /partnerWeb/partners/password
     */
    @POST
    @Path("/partners/password")
    public List<Object> createPassword(CreatePasswordDto dto) throws Exception {
        return partnerWebService.createPassword(
                dto.getAuthToken(),
                dto.getKlient(),
                dto.getPartnernr(),
                dto.getMail());
    }

    /**
     * Verify / check a postal address (external address verification service).
     *
     * POST /partnerWeb/partners/address/check
     */
    @POST
    @Path("/partners/address/check")
    public PostPruefAntwortTO pruefePostAdresse(AddressDto dto) throws Exception {
        return partnerWebService.pruefePostAdresse(
                (PostAdresseTO) dto.getAdresseTO(),
                dto.getaParameter());
    }

    // -------------------------------------------------------------------------
    // BRS transmission
    // -------------------------------------------------------------------------

    /**
     * Update the BRS transmission flag for a partner.
     *
     * PUT /partnerWeb/partners/brs
     */
    @POST
    @Path("/partners/brs")
    public void updateUebertragungBRS(UpdateUebertragungBRSDto dto) throws Exception {
        partnerWebService.updateUebertragungBRS(
                dto.getAuthToken(),
                dto.getKlient(),
                dto.getPartnernr(),
                dto.getBrsUebertragung());
    }

    // -------------------------------------------------------------------------
    // Duplicate detection
    // -------------------------------------------------------------------------

    /**
     * Get the head-duplicate partner number.
     *
     * POST /partnerWeb/duplicates/partner
     */
    @POST
    @Path("/duplicates/partner")
    public long getKopfDublettenPartnerNr(GetKopfDublettenDto dto) throws Exception {
        return partnerWebService.getKopfDublettenPartnerNr(
                dto.getKlient(),
                dto.getPartnernr());
    }

    /**
     * Get the head-duplicate address number.
     *
     * POST /partnerWeb/duplicates/address
     */
    @POST
    @Path("/duplicates/address")
    public int getKopfDublettenAdressNr(GetKopfDublettenAdressNrDto dto) throws Exception {
        return partnerWebService.getKopfDublettenAdressNr(
                dto.getKlient(),
                dto.getPartnernr(),
                dto.getaAdressNr());
    }

    /**
     * Get the head-duplicate bank connection number.
     *
     * POST /partnerWeb/duplicates/bank
     */
    @POST
    @Path("/duplicates/bank")
    public int getKopfDublettenBankVerbNr(PartnerbankLade dto) throws Exception {
        return partnerWebService.getKopfDublettenBankVerbNr(
                dto.getKlient(),
                dto.getPartnernr(),
                dto.getBankNr());
    }

    // -------------------------------------------------------------------------
    // Validation
    // -------------------------------------------------------------------------

    /**
     * Validate basic partner data (Grunddaten).
     *
     * POST /partnerWeb/validate/base-data
     */
    @POST
    @Path("/validate/base-data")
    public ValidationResult validiereGrunddaten(ValidierePartnerGrunddatenDto dto) throws Exception {
        return partnerWebService.validiereGrunddaten(
                dto.getPartnerTo(),
                dto.getaParameter());
    }

    /**
     * Validate cross-cutting partner rules (übergreifend).
     *
     * POST /partnerWeb/validate/cross-field
     */
    @POST
    @Path("/validate/cross-field")
    public ValidationResult validiereUebergreifend(ValidatePartnerDto dto) throws Exception {
        return partnerWebService.validiereUebergreifend(
                dto.getPartnerTo(),
                dto.getaParameter());
    }

    /**
     * Validate a partner address.
     *
     * POST /partnerWeb/validate/address
     */
    @POST
    @Path("/validate/address")
    public ValidationResult validiereAdresse(ValidateAddressDto dto) throws Exception {
        return partnerWebService.validiereAdresse(
                dto.getPartnerTo(),
                dto.getAdresseTO(),
                dto.getaParameter());
    }

    /**
     * Validate a partner bank connection.
     *
     * POST /partnerWeb/validate/bank
     */
    @POST
    @Path("/validate/bank")
    public ValidationResult validiereBankverbindung(ValidiereBankverbindungDto dto) throws Exception {
        return partnerWebService.validiereBankverbindung(
                dto.getPartnerTo(),
                dto.getAdresseTO(),
                dto.getaParameter());
    }

    // -------------------------------------------------------------------------
    // Utilities
    // -------------------------------------------------------------------------

    /**
     * Reserve a free partner number.
     *
     * POST /partnerWeb/partner-numbers/free
     */
    @POST
    @Path("/partner-numbers/free")
    public long holeFreiePartnerNummer(HoleFreiePartnerNummerDto dto) throws Exception {
        return partnerWebService.holeFreiePartnerNummer(
                dto.getAuthToken(),
                dto.getKlient(),
                dto.getaParameter());
    }

    /**
     * Get the current application release info.
     *
     * GET /partnerWeb/system/release
     */
    @POST
    @Path("/system/release")
    public String getReleaseInfo() {
        return partnerWebService.getReleaseInfo();
    }

}
