<p:dialog id="popupDialogAkte" widgetVar="popupDlg"
          header="KKE" modal="true" closable="false" resizable="false">

    <h:form id="kkeSubForm">
        <p:panelGrid columns="2" columnClasses="label,value" style="width:100%">

            <!-- Bearbeitungsdauer -->
            <h:outputLabel for="inpZeit" value="Bearbeitungsdauer (in Minuten):" />
            <p:inputText id="inpZeit"
                         value="#{kKEControllerMasch.kkeModel.bearbeitungsZeit}"
                         required="true"
                         size="10" maxlength="10"
                         onfocus="selectContent(this)">
                <f:convertNumber locale="de" minFractionDigits="1" maxFractionDigits="1" />
                <f:validator validatorId="KkeZeitwertValidator" />
            </p:inputText>
