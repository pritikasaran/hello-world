<p:toolbar style="width:100%">
    <p:toolbarGroup>

        <!-- Neu Laden -->
        <p:commandButton id="cmdNeuLaden" 
                         value="Aktualisieren"
                         action="#{postkorbVC.actionAktualisieren}" 
                         ajax="true"
                         icon="custom-icon"
                         styleClass="refresh-btn"
                         style="padding-left:2px; padding-right:2px;"/>

        <!-- Sortieren -->
        <p:commandButton id="cmdPkSort" 
                         value="Postkorb sortieren"
                         action="#{postkorbVC.sortierungEinstellen}" 
                         ajax="true"
                         icon="custom-icon"
                         styleClass="sort-btn"
                         style="padding-left:2px; padding-right:2px;"/>

        <!-- Termin bearbeiten -->
        <p:commandButton id="cmdTerminBearbeiten" 
                         value="Termin bearbeiten"
                         action="#{postkorbVC.bearbeiteTermin}" 
                         ajax="true"
                         icon="custom-icon"
                         styleClass="bearbeiten-btn"
                         process="@this"
                         update="@form"
                         style="padding-left:2px; padding-right:2px;"/>

        <!-- Weiterleiten/Wiedervorlage -->
        <p:commandButton id="cmdPkWW" 
                         value="Weiterleiten/Wiedervorlage"
                         action="#{postkorbVC.weiterleiten}" 
                         ajax="true"
                         icon="custom-icon"
                         styleClass="weiterleiten-btn"
                         style="padding-left:2px; padding-right:2px;"
                         rendered="#{!postkorbVC.postkorbModell.filter.erledigteTermine}"/>

        <!-- Kennzeichen ändern -->
        <p:commandButton id="cmdPkKzEdit" 
                         value="Kennzeichen ändern"
                         action="#{postkorbVC.kennzeichenAendern}" 
                         ajax="true"
                         icon="custom-icon"
                         styleClass="kzaendern-btn"
                         style="padding-left:2px; padding-right:2px;"
                         rendered="#{!postkorbVC.postkorbModell.filter.erledigteTermine}"/>

        <!-- Kundenkontakterfassung -->
        <p:commandButton id="cmdKKE" 
                         value="Kundenkontakterfassung"
                         action="#{postkorbVC.startKKE}" 
                         ajax="true"
                         icon="custom-icon"
                         styleClass="kke-btn"
                         immediate="true"
                         style="padding-left:2px; padding-right:2px;"
                         rendered="#{akteVC.akteModell.KKEBerechtigt}"/>

    </p:toolbarGroup>

    <!-- Right-aligned group -->
    <p:toolbarGroup align="right">
        <p:commandButton id="cmdTerminErledigenPostkorb" 
                         value="Termin erledigen"
                         action="#{postkorbVC.erledigenTermin}" 
                         ajax="true"
                         icon="custom-icon"
                         styleClass="erledigen-btn"
                         style="padding-left:2px; padding-right:2px;"
                         rendered="#{!postkorbVC.postkorbModell.filter.erledigteTermine}"/>
    </p:toolbarGroup>

</p:toolbar>
