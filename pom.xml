<h:form id="LoginForm">

    <p:panelGrid columns="2" cellpadding="7" style="width:100%;">
        
        <!-- User-ID -->
        <h:outputLabel value="User-ID:" />
        <h:outputText value="#{startVC.imsModelL.benutzerID}" />

        <!-- Token -->
        <h:outputLabel value="Token:" />
        <h:outputText value="#{startVC.imsModelL.token}" />

        <!-- Dokuid -->
        <h:outputLabel for="dokuid" value="Dokuid:" />
        <p:inputText id="dokuid" value="#{startVC.imsModelL.dokuidPrint}" />

        <!-- Error Message -->
        <h:outputLabel />
        <h:outputText id="errorMessage" value="#{startVC.errorMessage}" />

        <!-- Spacer -->
        <h:outputLabel />
        <h:panelGroup style="width:20px;" />

        <!-- Buttons -->
        <h:outputLabel />
        <h:panelGroup>
            <p:commandButton id="cmdStart" value="Start DocAnzeige2"
                             action="#{startVC.dokuanzeigeZwei}"
                             ajax="true"
                             disabled="#{startVC.weiterButtondisabled}"
                             onclick="registerWindowAttrs()" />
            
            <h:panelGroup style="display:inline-block; width:10px;" />

            <p:commandButton id="cmdCancel" value="Schliessen"
                             onclick="closeIMS()" />
        </h:panelGroup>

    </p:panelGrid>
</h:form>
