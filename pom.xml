<p:commandButton value="Neu Laden"
    action="#{postkorbVC.actionAktualisieren}"
    ajax="true"
    styleClass="refreshButton">
    <h:graphicImage library="images" name="refresh.gif" alt="Neu Laden" />
</p:commandButton>
<p:commandButton value="Sortieren"
    action="#{postkorbVC.sortierungEinstellen}"
    ajax="true"
    title="Postkorb sortieren"
    onclick="PF('sortDialog').show();">
    <h:graphicImage library="images" name="sortieren.gif" alt="Sortieren" />
</p:commandButton>

<p:dialog widgetVar="sortDialog" modal="true" width="500" height="400"
    onHide="#{postkorbVC.returnFromSortierenDialog}" />
<p:commandButton value="Öffnen/Schließen"
    action="#{postkorbVC.openClose}"
    ajax="true"
    onclick="PF('openCloseDialog').show();">
</p:commandButton>

<p:dialog widgetVar="openCloseDialog" modal="true" width="750" height="630">
    <!-- Dialog content -->
</p:dialog>

<p:setPropertyActionListener value="#{postkorbVC.postkorbModell.postkorbID}"
    target="#{postkorbOpenCloseVC.modell.postkorbID}" />
<p:setPropertyActionListener value="true"
    target="#{postkorbOpenCloseVC.modell.resetModell}" />
