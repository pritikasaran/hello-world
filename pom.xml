public void suchen() {
    try {
        // setup work
        EintraegeFilterModell filter = akteModell.getFilter();
        filter.resetValues();
        
        if (!StringUtils.isEmpty(akteModell.getOrb())) {
            filter.setMandant(akteModell.getMandant());
            filter.setOrbArt(akteModell.getOrbart());
            filter.setOrb(akteModell.getOrb());
        } else {
            filter.setMandant(null);
            filter.setOrbArt(null);
            filter.setOrb(null);
        }
        
        // only opens if no exception above
        PrimeFaces.current().executeScript(Pages.SUCHEN.getWindowOpenScript());
        
    } catch (Exception e) {
        LOG.severe("suchen error: " + e.getMessage());
        // show error to user
        FacesContext.getCurrentInstance().addMessage(null,
            new FacesMessage(FacesMessage.SEVERITY_ERROR, 
                "Fehler", e.getMessage()));
    }
}
