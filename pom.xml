<p:toolbar style="width:100%; padding:0; min-height:0;">
    <p:toolbarGroup style="display:table-cell; padding:0;">

        <!-- Neu Laden -->
        <h:commandButton id="cmdNeuLaden"
                         title="Aktualisieren"
                         action="#{postkorbVC.actionAktualisieren}"
                         style="padding-left:2px; padding-right:2px; border:none; background:transparent; cursor:pointer;">
            <h:graphicImage library="images" name="refresh.gif" alt="Aktualisieren"/>
            <f:ajax execute="@this" render="@form"/>
        </h:commandButton>

        <h:commandButton id="cmdPkSort"
                         title="Postkorb sortieren"
                         action="#{postkorbVC.sortierungEinstellen}"
                         style="padding-left:2px; padding-right:2px; border:none; background:transparent; cursor:pointer;">
            <h:graphicImage library="images" name="sortieren.gif" alt="Sortieren"/>
            <f:ajax execute="@this" render="@form"/>
        </h:commandButton>

        <h:commandButton id="cmdTerminBearbeiten"
                         title="Termin bearbeiten"
                         action="#{postkorbVC.bearbeiteTermin}"
                         style="padding-left:2px; padding-right:2px; border:none; background:transparent; cursor:pointer;">
            <h:graphicImage library="images" name="bearbeiten.gif" alt="Bearbeiten"/>
            <f:ajax execute="@this" render="@form"/>
        </h:commandButton>

        <h:commandButton id="cmdPkWW"
                         title="Weiterleiten/Wiedervorlage"
                         action="#{postkorbVC.weiterleiten}"
                         style="padding-left:2px; padding-right:2px; border:none; background:transparent; cursor:pointer;"
                         rendered="#{!postkorbVC.postkorbModell.filter.erledigteTermine}">
            <h:graphicImage library="images" name="weiterleiten.gif" alt="Weiterleiten"/>
            <f:ajax execute="@this" render="@form"/>
        </h:commandButton>

        <h:commandButton id="cmdPkKzEdit"
                         title="Kennzeichen ändern"
                         action="#{postkorbVC.kennzeichenAendern}"
                         style="padding-left:2px; padding-right:2px; border:none; background:transparent; cursor:pointer;"
                         rendered="#{!postkorbVC.postkorbModell.filter.erledigteTermine}">
            <h:graphicImage library="images" name="kzaendern2.gif" alt="Kennzeichen ändern"/>
            <f:ajax execute="@this" render="@form"/>
        </h:commandButton>

        <h:commandButton id="cmdKKE"
                         title="Kundenkontakterfassung"
                         action="#{postkorbVC.startKKE}"
                         immediate="true"
                         style="padding-left:2px; padding-right:2px; border:none; background:transparent; cursor:pointer;"
                         rendered="#{akteVC.akteModell.KKEBerechtigt}">
            <h:graphicImage library="images" name="kke.gif" alt="KKE"/>
            <f:ajax execute="@this" render="@form"/>
        </h:commandButton>

    </p:toolbarGroup>

    <p:toolbarGroup align="right" style="display:table-cell; padding:0;">
        <h:commandButton id="cmdTerminErledigenPostkorb"
                         title="Termin erledigen"
                         action="#{postkorbVC.erledigenTermin}"
                         style="padding-left:2px; padding-right:2px; border:none; background:transparent; cursor:pointer;"
                         rendered="#{!postkorbVC.postkorbModell.filter.erledigteTermine}">
            <h:graphicImage library="images" name="termin_erled.gif" alt="Termin erledigen"/>
            <f:ajax execute="@this" render="@form"/>
        </h:commandButton>
    </p:toolbarGroup>

</p:toolbar>
