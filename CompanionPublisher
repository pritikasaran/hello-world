@ApplicationScoped
@Path("/partnerWeb")
public class RestApplication3 {
	
	
	@Inject
	IPartnerWebService partnerWebService;
	

	public List<String[]> ladeSapPartnerInformation(String aPID) throws Exception {
		return partnerWebService.ladeSapPartnerInformation(aPID);
	}

	public void aktualisierePartner(PartnerSaveDto dto) throws Exception {
		partnerWebService.aktualisierePartner(dto.getAuthToken(),  dto.getPartnerTo(), dto.getaParameter());
	}

	public ValidationResult erzeugePartner(ValidatePartnerDto dto) throws Exception {
		return partnerWebService.erzeugePartner(dto.getAuthToken(), dto.getPartnerTo(), dto.getaParameter());
	}

	public ValidationResult validiereGrunddaten(ValidierePartnerGrunddatenDto dto)
			throws Exception {
		return partnerWebService.validiereGrunddaten( dto.getPartnerTo(), dto.getaParameter());
	}

	public ValidationResult validiereUebergreifend(ValidatePartnerDto dto)
			throws Exception {
		return partnerWebService.validiereUebergreifend( dto.getPartnerTo(), dto.getaParameter());
	}

	public PartnerTO ladePartner(PartnerLadeDto dto)
			throws Exception {
		return partnerWebService.ladePartner(dto.getAuthToken(), dto.isNebendubletteaufloesen(), dto.getKlient(), dto.getPartnernr(), dto.getParameter());
	}

	public List<EinzelVsnrTO> getNeusteEinzelVsnr(GetNeusteEinzelVsnrDto dto)
			throws Exception {
		return partnerWebService.getNeusteEinzelVsnr(dto.getAuthToken(), dto.getMandant(), dto.getOrbart(), dto.getOrb());
	}

	public int getKopfDublettenBankVerbNr(PartnerbankLade dto)
			throws Exception {
		return partnerWebService.getKopfDublettenBankVerbNr(dto.getKlient(), dto.getPartnernr(), dto.getBankNr());
	}

	public PostPruefAntwortTO pruefePostAdresse(AddressDto dto)
			throws Exception {
		return partnerWebService.pruefePostAdresse((PostAdresseTO) dto.getAdresseTO(), dto.getaParameter());
	}

	public BankVerbindungTO ladePartnerBankverbindung(PartnerbankLade dto) throws Exception {
		return partnerWebService.ladePartnerBankverbindung(dto.getAuthToken(), dto.getKlient(), dto.getPartnernr(), dto.getBankNr(), dto.getParameter());
	}

	public ValidationResult validiereAdresse(ValidateAddressDto dto)
			throws Exception {
		return partnerWebService.validiereAdresse(dto.getPartnerTo(), dto.getAdresseTO(), dto.getaParameter());
	}

	public ValidationResult validiereBankverbindung(ValidiereBankverbindungDto dto) throws Exception {
		return partnerWebService.validiereBankverbindung(dto.getPartnerTo(), dto.getAdresseTO(), dto.getaParameter());
	}

	public PostAdresseTO ladePartnerPostAdresse(LadePartnerPostAdresseDto dto)
			throws Exception {
		return partnerWebService.ladePartnerPostAdresse(dto.getAuthToken(), dto.getKlient(), dto.getPartnernr(), dto.getaAnschrnr(), dto.getParameter());
	}

	public long getKopfDublettenPartnerNr(GetKopfDublettenDto dto) throws Exception {
		return partnerWebService.getKopfDublettenPartnerNr(dto.getKlient(), dto.getPartnernr());
	}

	public int getKopfDublettenAdressNr(GetKopfDublettenAdressNrDto dto) throws Exception {
		return partnerWebService.getKopfDublettenAdressNr(dto.getKlient(), dto.getPartnernr(), dto.getaAdressNr());
