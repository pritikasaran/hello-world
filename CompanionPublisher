<h:outputScript target="body">
    window.addEventListener('load', function() {
        setTimeout(function() {
            var selected = document.querySelector('#panelTabbs\\:aktenansichtSubForm\\:tabVorgaenge .ui-state-highlight');
            var scrollBody = document.querySelector('#panelTabbs\\:aktenansichtSubForm\\:tabVorgaenge .ui-datatable-scrollable-body');
            if (selected && scrollBody) {
                scrollBody.scrollTop = selected.getBoundingClientRect().top - scrollBody.getBoundingClientRect().top + scrollBody.scrollTop;
            }
        }, 500);
    });
</h:outputScript>
