	public long holeFreiePartnerNummer(HoleFreiePartnerNummerDto dto) throws Exception {
		return partnerWebService.holeFreiePartnerNummer(dto.getAuthToken(), dto.getKlient(), dto.getaParameter());
	}

	public void updateUebertragungBRS(UpdateUebertragungBRSDto dto )
			throws Exception {
		partnerWebService.updateUebertragungBRS(dto.getAuthToken(), dto.getKlient(), dto.getPartnernr(), dto.getBrsUebertragung());

	}

	public PartnerBilanzdaten getbilanzdaten(Integer klient, Long partnernr) throws Exception {
		return partnerWebService.getbilanzdaten(klient, partnernr);
	}

	public String getReleaseInfo() {
		return partnerWebService.getReleaseInfo();
	}

	public List<JournalEintragTO> ladeJournalFuerPartner(PartnerLadeDto dto)
			throws Exception {
		return partnerWebService.ladeJournalFuerPartner(dto.getKlient(), dto.getKlient());
	}
	
	public List<Object> CreatePassword(CreatePasswordDto dto)
			throws Exception {
		List<Object> list = partnerWebService.createPassword(dto.getAuthToken(), dto.getKlient(), dto.getPartnernr(), dto.getMail());
		return 	list;

	}

